# Environment Configuration Template
# Copy this to .env and fill in actual values

# ===================================
# OPENAI CONFIGURATION
# ===================================
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ===================================
# COHERE CONFIGURATION
# ===================================
COHERE_API_KEY=your-cohere-key-here
COHERE_MODEL=command
COHERE_TEMPERATURE=0.7

# ===================================
# DATABASE CONFIGURATION
# ===================================
# For Streamlit Cloud, use Neon or Supabase PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/csc_governance
POSTGRES_USER=csc_user
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=csc_governance
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# For Neon (recommended for production)
# DATABASE_URL=postgresql://[user]:[password]@[neon-host]/[database]?sslmode=require

# For Supabase
# DATABASE_URL=postgresql://[user]:[password]@[supabase-host]:5432/[database]?sslmode=require

# ===================================
# CHROMADB CONFIGURATION
# ===================================
CHROMA_DB_PATH=./knowledge_base/vectorstore
CHROMA_PERSIST_DIRECTORY=./knowledge_base/vectorstore
CHROMA_USE_EMBEDDING_API=false

# ===================================
# EMBEDDINGS CONFIGURATION
# ===================================
EMBEDDINGS_MODEL=BAAI/bge-large-en-v1.5
HF_API_TOKEN=your-huggingface-token
EMBEDDINGS_BATCH_SIZE=32

# ===================================
# TAVILY SEARCH
# ===================================
TAVILY_API_KEY=your-tavily-key-here

# ===================================
# AUDIO/SPEECH CONFIGURATION
# ===================================
AUDIO_ENABLED=true
WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
AUDIO_FORMAT=wav

# ===================================
# LANGCHAIN CONFIGURATION
# ===================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langchain-api-key
LANGCHAIN_PROJECT=csc-governance
LANGCHAIN_VERBOSE=false

# ===================================
# APPLICATION SETTINGS
# ===================================
APP_NAME=CSC Mitra AI
APP_ENV=production
DEBUG_MODE=false
LOG_LEVEL=INFO

# ===================================
# STREAMLIT SETTINGS
# ===================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_CLIENT_TOOLBAR_MODE=viewer

# ===================================
# FILE UPLOAD SETTINGS
# ===================================
MAX_FILE_UPLOAD_MB=200
ALLOWED_FILE_TYPES=pdf,docx,txt,png,jpg,jpeg
UPLOAD_TEMP_DIR=./temp_uploads

# ===================================
# FEATURE FLAGS
# ===================================
ENABLE_VOICE_FEATURES=true
ENABLE_OCR=true
ENABLE_DOCUMENT_VERIFICATION=true
ENABLE_HUMAN_IN_LOOP=true

# ===================================
# RAG SETTINGS
# ===================================
RETRIEVAL_TOP_K=5
RERANK_TOP_K=3
SIMILARITY_THRESHOLD=0.3
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ===================================
# SLA CONFIGURATION
# ===================================
SLA_CRITICAL_HOURS=24
SLA_HIGH_HOURS=48
SLA_MEDIUM_HOURS=120
SLA_LOW_HOURS=240

# ===================================
# SECURITY
# ===================================
SECRET_KEY=your-secret-key-for-sessions
JWT_SECRET=your-jwt-secret
JWT_EXPIRATION_HOURS=24
ENABLE_CORS=true
ALLOWED_ORIGINS=*

# ===================================
# NOTIFICATION SETTINGS
# ===================================
ENABLE_EMAIL_NOTIFICATIONS=true
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@cscmitra.in

# ===================================
# ANALYTICS
# ===================================
ENABLE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=90

# ===================================
# MONITORING
# ===================================
SENTRY_DSN=your-sentry-dsn
ENABLE_ERROR_TRACKING=true
PERFORMANCE_MONITORING=true
